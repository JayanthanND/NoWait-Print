{
    "name": "printer-backend",
    "version": "1.0.0",
    "description": "Backend for print-order SaaS",
    "main": "dist/index.js",
    "scripts": {
        "start": "node dist/index.js",
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "build": "tsc",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "seed": "ts-node prisma/seed.ts"
    },
    "dependencies": {
        "@prisma/client": "^6.3.0",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.18.2",
        "multer": "^1.4.5-lts.1",
        "pdf-lib": "^1.17.1",
        "sharp": "^0.33.2"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/multer": "^1.4.11",
        "@types/node": "^20.11.16",
        "prisma": "^6.3.0",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3"
    }
}