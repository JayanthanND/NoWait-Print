generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64", "windows"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Shop {
  id              String   @id @default(uuid())
  name            String
  upiId           String?
  bankDetails     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  orders          Order[]
}

model Order {
  id              String      @id @default(uuid())
  shopId          String
  shop            Shop        @relation(fields: [shopId], references: [id])
  mobile          String
  totalAmount     Float       @default(0)
  status          String      @default("PENDING") // PENDING, COMPLETED, PAID
  paymentStatus   String      @default("UNPAID")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  works           Work[]
}

model Work {
  id              String      @id @default(uuid())
  orderId         String
  order           Order       @relation(fields: [orderId], references: [id])
  pageSize        String      // A4, A3
  colorType       String      // BW, COLOR
  printSide       String      // SINGLE, DOUBLE
  copies          Int         @default(1)
  bindingType     String?     // SPIRAL, STAPLE, TAPE, NONE
  paperType       String?     // REGULAR, GLOSSY, MATTE
  gsm             String?     // 80, 100, 120
  calculatedPrice Float       @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  files           File[]
}

model File {
  id              String   @id @default(uuid())
  workId          String
  work            Work     @relation(fields: [workId], references: [id])
  originalName    String
  filePath        String
  fileType        String   // PDF, IMAGE
  pageCount       Int      @default(0) // Detected pages
  printablePages  Int      @default(0) // Logical pages to print
  createdAt       DateTime @default(now())
}

model PricingRule {
  id              String   @id @default(uuid())
  pageSize        String   // A4
  colorType       String   // BW
  printSide       String   // SINGLE
  basePrice       Float
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([pageSize, colorType, printSide])
}

model BindingOption {
  id              String   @id @default(uuid())
  name            String   // Spiral, Hardcover
  price           Float
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PaperType {
  id              String   @id @default(uuid())
  name            String   // Regular, Glossy
  price           Float
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model GSMOption {
  id              String   @id @default(uuid())
  value           String   // 75, 80, 100
  price           Float
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
